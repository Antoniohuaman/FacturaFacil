# Variables runtime para `npm run dev:pm:cf`
# Copia este archivo como `/.dev.vars` y completa los valores reales.
# No commitees `/.dev.vars`.

# Auth/server-side del Portal PM
PM_PORTAL_SUPABASE_URL=
PM_PORTAL_SUPABASE_ANON_KEY=
PM_PORTAL_SUPABASE_SERVICE_ROLE_KEY=

# Lectura de retroalimentación desde el Supabase de SenciYo
SENCIYO_SUPABASE_URL=
SENCIYO_SUPABASE_SERVICE_ROLE_KEY=

# Autorización de aplicación para la API oficial v1 agregada
# token_hash esperado en FEEDBACK_API_CONSUMERS_JSON: sha256("<pepper>:<token>")
FEEDBACK_API_CONSUMERS_JSON=
FEEDBACK_API_KEY_HASH_PEPPER=

# Habilita `GET /api/v1/retroalimentacion/panel` solo cuando está en true.
# Default seguro recomendado en local: false.
FEEDBACK_API_V1_PANEL_ENABLED=false

# PostHog (solo si se usan métricas en local)
POSTHOG_HOST=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# GitHub (solo si se usa `/api/resumen-repo`)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# Diagnóstico opcional
DIAGNOSTICO_METRICAS=false

# Compatibilidad legada opcional:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
