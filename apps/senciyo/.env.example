# Variables de entorno — SenciYo
# Copia este archivo como .env.local y completa los valores para desarrollo local.
# NUNCA commitees .env.local ni ningún archivo con valores reales.

# ── API Backend ──────────────────────────────────────────────────────────────
# URL base del backend (por defecto usa mock local si está vacío)
VITE_API_URL=

# Activa el modo demo/mock sin backend real (true | false)
VITE_DEV_MODE=false

# ── Indicadores de negocio ───────────────────────────────────────────────────
VITE_INDICADORES_API_URL=
VITE_INDICADORES_NOTIFICACIONES_API_URL=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Necesario para persistir retroalimentación real desde el frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Analítica (claves publishable — son públicas, pero no se commitean en .env) ─
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_AMPLITUDE_API_KEY=
# Session Replay de Amplitude. 0 desactiva capture por defecto;
# súbelo explícitamente en producción cuando exista una decisión de privacidad/cuota.
VITE_PUBLIC_AMPLITUDE_SESSION_REPLAY_SAMPLE_RATE=0
VITE_PUBLIC_MIXPANEL_TOKEN=
