{
  "name": "portal-pm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "kill-port 5181 && vite --port 5181 --strictPort --open",
    "generar:estado": "node scripts/generarEstadoDespliegue.mjs",
    "build": "npm run generar:estado && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "kill-port 5182 && vite preview --port 5182 --strictPort --open",
    "validar": "npm run lint && npm run build",
    "dev:sin-abrir": "kill-port 5181 && vite --port 5181 --strictPort",
    "previsualizar": "npm run preview"
  },
  "dependencies": {
    "@facturafacil/analytics-events": "*",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.9.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
