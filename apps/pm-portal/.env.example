# Variables de entorno — PM-Portal
# Copia este archivo como .env.local y completa los valores para desarrollo local.
# NUNCA commitees .env.local ni ningún archivo con valores reales.

# ── Supabase (cliente, lado browser) ─────────────────────────────────────────
# Clave pública (anon key) — No tiene acceso a datos sensibles gracias a las políticas RLS
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Variables de servidor — Cloudflare Pages Functions ────────────────────────
# Estas variables NO van en este archivo .env.
# En producción se configuran en el panel de Cloudflare Pages → Settings → Environment variables.
# Para desarrollo local con Wrangler, van en el archivo .dev.vars (ignorado por git).
#
# SUPABASE_URL=                    (igual que VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=       ⚠ Clave de servicio — acceso total, nunca al cliente
# POSTHOG_HOST=                    (ej: https://us.i.posthog.com)
# POSTHOG_PROJECT_ID=
# POSTHOG_PERSONAL_API_KEY=        ⚠ Clave personal de PostHog — solo servidor
# GITHUB_OWNER=                    (opcional, para el endpoint resumen-repo)
# GITHUB_REPO=                     (opcional)
# GITHUB_TOKEN=                    (opcional)
# DIAGNOSTICO_METRICAS=            (opcional, activa logs de diagnóstico en el servidor)
