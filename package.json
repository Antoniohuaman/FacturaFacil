{
  "name": "facturafacil-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:senciyo",
    "build": "npm run build:senciyo && npm run build:pm",
    "lint": "npm run lint:senciyo && npm run lint:pm",
    "dev:senciyo": "npm run dev -w senciyo",
    "build:senciyo": "npm run build -w senciyo",
    "lint:senciyo": "npm run lint -w senciyo",
    "dev:pm": "npm run dev -w portal-pm",
    "build:pm": "npm run build -w portal-pm",
    "lint:pm": "npm run lint -w portal-pm",
    "typecheck:functions": "tsc --project functions/tsconfig.json"
  }
}
